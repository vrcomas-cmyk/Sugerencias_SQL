# api.py lee estas variables de entorno vía python-dotenv (load_dotenv() al
# arrancar, lee .env si existe). En Railway/Render configúralas en el panel
# del servicio en vez de subir un .env.

# URL del proyecto Supabase de degasa-portal (mismo que VITE_SUPABASE_URL).
SUPABASE_URL=https://fiplfsuhsqibzrpvjvbx.supabase.co

# Clave anon/publishable del mismo proyecto (mismo que VITE_SUPABASE_ANON_KEY).
# Se usa solo para validar tokens contra /auth/v1/user — no da acceso a datos.
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Orígenes permitidos por CORS, separados por coma. Incluye tu dominio de
# producción cuando lo tengas.
ALLOWED_ORIGINS=http://localhost:5173

# Cloudflare R2 — mismas credenciales que ya usa la Edge Function r2-presign
# de Supabase (bucket "degasa-portal"). Aquí se usan para acumular
# Facturación (r2_client.py) — ver README.
R2_ENDPOINT=https://e583a393ae8a07aa48243eef406fdcd8.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET=degasa-portal
